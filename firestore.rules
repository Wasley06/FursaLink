rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -----------------------------------------------------------
    // HELPER FUNCTIONS
    // -----------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function getAuthUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isChairman() { return isSignedIn() && getAuthUser().role in ['chairman', 'admin']; }
    function isController() { return isSignedIn() && getAuthUser().role == 'controller'; }
    function isCandidate() { return isSignedIn() && getAuthUser().role == 'candidate'; }
    function isDeveloper() { return isSignedIn() && getAuthUser().role == 'developer'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -----------------------------------------------------------
    // GLOBAL CATCH-ALL
    // -----------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------
    // USERS COLLECTION
    // -----------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
               data.phoneNumber is string && data.phoneNumber.size() >= 8 && data.phoneNumber.size() <= 20 &&
               data.role in ['candidate', 'controller', 'chairman', 'developer', 'admin'];
      }

      // Read: Self, or Controller/Admin (if authorized)
      allow get: if isSignedIn() && (isOwner(userId) || isChairman() || isDeveloper() || isController());
      allow list: if isSignedIn() && (
        isChairman() ||
        isDeveloper() ||
        (isController() && resource.data.role == 'candidate' && resource.data.district == getAuthUser().district)
      );

      // Create:
      // - Self-registration: doc id must equal uid
      // - Seed/demo: chairman/developer can create demo users only (isDemo=true)
      allow create: if isSignedIn() && isValidUser(incoming()) && (
        (isOwner(userId) && incoming().createdAt == request.time) ||
        ((isChairman() || isDeveloper()) && incoming().isDemo == true)
      );

      // Update: Self (role can't change) or Controller/Chairman
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().role == existing().role &&
          (
            (incoming().phoneVerified == existing().phoneVerified) ||
            (incoming().phoneVerified == true && request.auth.token.phone_number != null)
          ) && incoming().updatedAt == request.time) ||
        isChairman() ||
        isDeveloper() ||
        (isController() && existing().district == getAuthUser().district && incoming().role == existing().role)
      );

      // Delete: Only demo documents can be deleted (safety).
      allow delete: if isSignedIn() && (isChairman() || isDeveloper()) && existing().isDemo == true;
    }

    // -----------------------------------------------------------
    // SYSTEM CONFIG (GLOBAL DOC)
    // -----------------------------------------------------------
    match /systemConfig/{docId} {
      // Read the global configuration publicly so maintenance mode can be shown before login.
      allow get: if docId == 'global';
      allow list: if false;

      // Write: Chairman + Developer only.
      allow create, update: if isSignedIn() && (isChairman() || isDeveloper());
      allow delete: if false;
    }

    // -----------------------------------------------------------
    // JOBS COLLECTION
    // -----------------------------------------------------------
    match /jobs/{jobId} {
      function isValidJob(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.description is string &&
               data.status in ['published', 'unpublished', 'paused', 'closed'];
      }

      allow read: if isSignedIn();
      allow create: if (isChairman() || isDeveloper() || isController()) && isValidJob(incoming()) && incoming().createdAt == request.time;
      allow update: if (isChairman() || isDeveloper() || (isController() && existing().controllerId == request.auth.uid)) && isValidJob(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isChairman() || isDeveloper();
    }

    // -----------------------------------------------------------
    // APPLICATIONS COLLECTION
    // -----------------------------------------------------------
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.jobId is string && data.userId is string &&
               data.status in ['pending', 'approved', 'rejected', 'shortlisted'];
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isChairman() || isDeveloper() || isController());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isChairman() || isDeveloper() || isController());

      // Create: Candidate only
      allow create: if isCandidate() && incoming().userId == request.auth.uid && isValidApplication(incoming()) && incoming().appliedAt == request.time;

      // Update: Controller or Admin (status only)
      allow update: if (isChairman() || isDeveloper() || isController()) && incoming().userId == existing().userId && incoming().jobId == existing().jobId && isValidApplication(incoming()) && incoming().updatedAt == request.time;
    }

    // -----------------------------------------------------------
    // NOTICES / ADS
    // -----------------------------------------------------------
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isChairman() || isDeveloper() || isController();
    }

    match /ads/{adId} {
      allow read: if isSignedIn();
      allow write: if isChairman() || isDeveloper() || isController();
    }

    // -----------------------------------------------------------
    // MESSAGES
    // -----------------------------------------------------------
    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // -----------------------------------------------------------
    // COURSES / EVENTS + ENROLLMENTS / BOOKINGS
    // -----------------------------------------------------------
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isChairman() || isDeveloper() || isController();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isChairman() || isDeveloper() || isController();
    }

    match /courseEnrollments/{enrollmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isChairman() || isController());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isChairman() || isController());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -----------------------------------------------------------
    // APPROVAL WORKFLOW (Controller -> Chairman)
    // -----------------------------------------------------------
    match /approvalRequests/{requestId} {
      allow read: if isSignedIn() && (isChairman() || isDeveloper() || (isController() && resource.data.controllerId == request.auth.uid));
      allow create: if isController() && incoming().controllerId == request.auth.uid && incoming().status == 'pending';
      allow update: if isChairman() || isDeveloper();
      allow delete: if isChairman() || isDeveloper();
    }

    match /approvalLogs/{logId} {
      allow read: if isSignedIn() && (isChairman() || isDeveloper());
      allow create: if isSignedIn() && (isChairman() || isDeveloper());
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn() && (isChairman() || isDeveloper());
      allow create: if isSignedIn() && (isChairman() || isDeveloper() || isController());
    }

    // -----------------------------------------------------------
    // PRESENCE (ONLINE/OFFLINE)
    // -----------------------------------------------------------
    match /presence/{userId} {
      allow read: if isSignedIn() && (isChairman() || isDeveloper());
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // -----------------------------------------------------------
    // NOTIFICATIONS
    // -----------------------------------------------------------
    match /notifications/{notifId} {
      allow get, list: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid ||
        isChairman() ||
        isDeveloper()
      );

      allow create: if isSignedIn() &&
        incoming().senderId == request.auth.uid &&
        incoming().recipientId is string &&
        incoming().title is string &&
        incoming().title.size() > 0 &&
        incoming().title.size() <= 140 &&
        incoming().createdAt == request.time;

      // Recipient can mark as read only.
      allow update: if isSignedIn() &&
        resource.data.recipientId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['read', 'updatedAt']);

      allow delete: if isChairman() || isDeveloper();
    }
  }
}
