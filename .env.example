# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase (client) configuration.
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to the browser bundle.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_MEASUREMENT_ID=""
# Optional: non-default Firestore database id (if you use multiple databases)
VITE_FIRESTORE_DATABASE_ID=""

# Storage provider (defaults to Supabase if configured, otherwise Firebase)
VITE_STORAGE_PROVIDER="supabase"

# Supabase Storage (client)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_BUCKET_PUBLIC="public-assets"
VITE_SUPABASE_BUCKET_PRIVATE="private-assets"

# Supabase Storage (server - Vercel Functions)
# NOTE: Do NOT prefix these with VITE_ (they must stay server-only).
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_BUCKET_PUBLIC="public-assets"
SUPABASE_BUCKET_PRIVATE="private-assets"

# Firebase Admin (server - used to verify Firebase ID tokens in /api/storage/*)
FIREBASE_ADMIN_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxxx@YOUR_FIREBASE_PROJECT_ID.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Invitation codes for officer registration links (client-side gate).
# For strong security, enforce invite validation server-side (e.g., custom claims).
VITE_INVITE_CONTROLLER_CODE="CHANGE_ME"
VITE_INVITE_CHAIRMAN_CODE="CHANGE_ME"
VITE_INVITE_DEVELOPER_CODE="CHANGE_ME"

# Demo auth (local-only convenience). Keep disabled for production builds.
VITE_ENABLE_DEMO_AUTH="true"
VITE_DEMO_PIN="12345678"

# Demo dataset seeding (used by `npm run seed:demo-dataset`)
FURSALINK_DEMO_CANDIDATE_COUNT="1370"
FURSALINK_DEMO_CONTROLLER_PASSWORD="CHANGE_ME"

# Developer bootstrap (used by `npm run seed:dev-user`)
FURSALINK_DEV_USERNAME="Wasley DEV"
FURSALINK_DEV_PASSWORD="Kingsley06#"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
